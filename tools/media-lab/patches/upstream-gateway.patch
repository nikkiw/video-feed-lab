diff --git a/scripts/media-ingest.sh b/scripts/media-ingest.sh
index eb4c0b0..d51e9ea 100755
--- a/scripts/media-ingest.sh
+++ b/scripts/media-ingest.sh
@@ -129,13 +129,26 @@ process_file() {
       ;;
   esac
 
-  if [ "$source_width" -le "$source_height" ]; then
-    source_short=$source_width
-    orientation=portrait
-  else
-    source_short=$source_height
-    orientation=landscape
-  fi
+  # Always crop to exactly 9:16 portrait to standardize all videos
+  crop_dims=$(awk -v w="$source_width" -v h="$source_height" '
+    BEGIN {
+      cw = w; ch = h;
+      if (w * 16 > h * 9) {
+        cw = int(h * 9 / 16 / 2) * 2;
+      } else {
+        ch = int(w * 16 / 9 / 2) * 2;
+      }
+      print cw "x" ch;
+    }
+  ')
+  crop_width=${crop_dims%x*}
+  crop_height=${crop_dims#*x}
+
+  source_width=$crop_width
+  source_height=$crop_height
+  source_short=$source_width
+  orientation=portrait
+  crop_filter="crop=$crop_width:$crop_height,"
 
